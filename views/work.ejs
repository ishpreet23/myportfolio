<!-- Interactive filtering JS -->
<script>
    (function initGalleryFilter() {
        const buttons = document.querySelectorAll('#filter-wrapper button');
        const cards = document.querySelectorAll('#gallery-grid .project-card');

        buttons.forEach(btn => {
            btn.addEventListener('click', () => {
                // Deactivate all buttons
                buttons.forEach(b => {
                    b.classList.remove('border-secondary-container/50', 'text-secondary-container');
                    b.classList.add('border-outline-variant/30', 'text-outline');
                });

                // Activate current button
                btn.classList.remove('border-outline-variant/30', 'text-outline');
                btn.classList.add('border-secondary-container/50', 'text-secondary-container');

                const filterValue = btn.textContent.trim().toLowerCase();

                cards.forEach(card => {
                    const cardCategory = card.getAttribute('data-category').toLowerCase();
                    if (filterValue === 'all_projects' || cardCategory === filterValue) {
                        card.style.display = 'block';
                        setTimeout(() => {
                            card.style.opacity = '1';
                            card.style.transform = 'translateY(0)';
                        }, 50);
                    } else {
                        card.style.opacity = '0';
                        card.style.transform = 'translateY(20px)';
                        setTimeout(() => {
                            card.style.display = 'none';
                        }, 300);
                    }
                });
            });
        });
    })();
</script>
