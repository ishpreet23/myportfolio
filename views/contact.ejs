            <div class="mt-8 pt-8 border-t border-outline-variant/20 flex justify-between items-center">
                <div class="font-mono-data text-[10px] text-outline italic terminal-text" id="encryption-label">ENCRYPTION: AES-256</div>
                <div class="font-mono-data text-[10px] text-outline italic terminal-text" id="location-label">LOCATION: 30.7333° N, 76.7794° E</div>
            </div>
        </div>
