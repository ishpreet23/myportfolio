<script>
(function initContactPage() {

    // ==========================
    // Live Terminal Animation
    // ==========================

    const encryptionEl = document.getElementById("encryption-label");
    const locationEl = document.getElementById("location-label");

    const hexChars = "0123456789ABCDEF";

    setInterval(() => {

        if(encryptionEl){

            let hex = "";

            for(let i=0;i<4;i++){
                hex += hexChars[Math.floor(Math.random()*16)];
            }

            encryptionEl.innerText =
                `ENCRYPTION: AES-256 [0x${hex}]`;
        }

        if(locationEl){

            const lat = (30.7333 + (Math.random()-0.5)*0.0001).toFixed(4);
            const lng = (76.7794 + (Math.random()-0.5)*0.0001).toFixed(4);

            locationEl.innerText =
                `LOCATION: ${lat}° N, ${lng}° E`;
        }

    },100);

    // ==========================
    // Contact Form
    // ==========================

    const form = document.getElementById("contact-form");

    if(!form) return;

    form.addEventListener("submit",function(e){

        e.preventDefault();

        const name =
            form.querySelector('input[type="text"]').value.trim();

        const email =
            form.querySelector('input[type="email"]').value.trim();

        const phone =
            form.querySelector('input[type="tel"]').value.trim();

        const budgetField =
            form.querySelector('select, input[name="budget"]');

        const budget = budgetField ? budgetField.value : "Not Mentioned";

        const project =
            form.querySelector("textarea").value.trim();

        const button =
            form.querySelector("button[type='submit']");

        const originalHTML = button.innerHTML;

        button.disabled = true;

        button.innerHTML = `
            <span class="material-symbols-outlined animate-spin">
                refresh
            </span>
            CONNECTING...
        `;

        // ==========================
        // WhatsApp Message
        // ==========================

        const message = `🚀 *New Portfolio Inquiry*

👤 *Name*
${name}

📧 *Email*
${email}

📱 *Phone*
${phone}

💰 *Budget*
${budget}

📝 *Project Brief*
${project}

🌐 *Sent From*
${window.location.origin}`;

        const phoneNumber = "917009842667";

        const whatsappURL =
            `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;

        setTimeout(()=>{

            button.innerHTML = `
                <span class="material-symbols-outlined">
                    check_circle
                </span>
                REDIRECTING...
            `;

            button.classList.remove("bg-secondary-fixed");
            button.classList.add("bg-white","text-black");

            window.open(whatsappURL,"_blank");

            setTimeout(()=>{

                button.innerHTML = originalHTML;

                button.classList.remove("bg-white","text-black");
                button.classList.add("bg-secondary-fixed");

                button.disabled = false;

                form.reset();

            },1500);

        },800);

    });

})();
</script>